# N4ughtyLLM Gate tunables (copy to config/.env and edit; restart to apply unless hot-reload is supported)
# Variable names use the N4UGHTYLLM_GATE_ prefix; see README "Configuration" for the full list.

# ─── Logging & runtime ─────────────────────────────────────
N4UGHTYLLM_GATE_LOG_LEVEL=info
# In DEBUG, log full request bodies (default false: method/path/route/headers + body_size only)
N4UGHTYLLM_GATE_LOG_FULL_REQUEST_BODY=false
N4UGHTYLLM_GATE_ENV=prod

# ─── Security level & gateway ─────────────────────────────
# low: mostly redact | medium (default): strict on high risk + redact | high: full detection
N4UGHTYLLM_GATE_SECURITY_LEVEL=medium
# If true, force-block on strict command patterns regardless of security_level threshold
N4UGHTYLLM_GATE_STRICT_COMMAND_BLOCK_ENABLED=false
# Gateway key loads from config/n4ughtyllm_gate_gateway.key (auto-created, chmod 600)
# Show: cat config/n4ughtyllm_gate_gateway.key
# Override in Docker/CI: N4UGHTYLLM_GATE_GATEWAY_KEY=<your-key>
N4UGHTYLLM_GATE_DEFAULT_POLICY=default
# Comma-separated trusted reverse-proxy IPs (CIDR ok, e.g. 172.16.0.0/12); only their XFF is trusted.
# Empty = trust direct client IP only (safest default).
N4UGHTYLLM_GATE_TRUSTED_PROXY_IPS=
# Loopback-only access; set false for Docker (compose sets this)
N4UGHTYLLM_GATE_ENFORCE_LOOPBACK_ONLY=true
# Empty = auto-write Fernet key to config/n4ughtyllm_gate_fernet.key
# N4UGHTYLLM_GATE_ENCRYPTION_KEY=
# Risk score threshold 0–1; lower = stricter
N4UGHTYLLM_GATE_RISK_SCORE_THRESHOLD=0.7

# ─── UI session ───────────────────────────────────────────
N4UGHTYLLM_GATE_LOCAL_UI_SESSION_TTL_SECONDS=43200
N4UGHTYLLM_GATE_LOCAL_UI_LOGIN_RATE_LIMIT_PER_MINUTE=10
N4UGHTYLLM_GATE_LOCAL_UI_SECURE_COOKIE=true
N4UGHTYLLM_GATE_LOCAL_UI_ALLOW_INTERNAL_NETWORK=false

# ─── Upstream & limits ────────────────────────────────────
# Default v1 upstream; when set you can call /v1/... without token registration
# N4UGHTYLLM_GATE_UPSTREAM_BASE_URL=http://localhost:8317/v1
N4UGHTYLLM_GATE_UPSTREAM_TIMEOUT_SECONDS=600
N4UGHTYLLM_GATE_UPSTREAM_MAX_CONNECTIONS=300
N4UGHTYLLM_GATE_UPSTREAM_MAX_KEEPALIVE_CONNECTIONS=100
N4UGHTYLLM_GATE_ENABLE_THREAD_OFFLOAD=false
N4UGHTYLLM_GATE_FILTER_PIPELINE_TIMEOUT_S=90
# On request pipeline timeout: block (default) or pass (legacy)
N4UGHTYLLM_GATE_REQUEST_PIPELINE_TIMEOUT_ACTION=block
N4UGHTYLLM_GATE_MAX_REQUEST_BODY_BYTES=12000000
N4UGHTYLLM_GATE_MAX_MESSAGES_COUNT=300
N4UGHTYLLM_GATE_MAX_CONTENT_LENGTH_PER_MESSAGE=250000
N4UGHTYLLM_GATE_MAX_PENDING_PAYLOAD_BYTES=1200000
N4UGHTYLLM_GATE_MAX_RESPONSE_LENGTH=2000000
# Admin endpoint rate limit per IP per minute
N4UGHTYLLM_GATE_ADMIN_RATE_LIMIT_PER_MINUTE=30

# ─── Circuit breaker (live traffic failure feedback) ──────
# Auto-trips open when upstream requests fail consecutively during live traffic.
# Tripped circuit excludes provider from model-group routing until the back-off
# window expires (half-open probe) and enough successes re-close it.
# Set to false to disable entirely (health-check results still recorded).
N4UGHTYLLM_GATE_CIRCUIT_BREAKER_ENABLED=true
# Consecutive failures before circuit opens (per provider).
N4UGHTYLLM_GATE_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
# Minimum open window in seconds (exponential back-off starts here).
N4UGHTYLLM_GATE_CIRCUIT_BREAKER_BASE_OPEN_SECONDS=10.0
# Hard ceiling on the back-off window.
N4UGHTYLLM_GATE_CIRCUIT_BREAKER_MAX_OPEN_SECONDS=300.0
# Consecutive successes required in HALF_OPEN state to fully close circuit.
N4UGHTYLLM_GATE_CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2
# Jitter factor 0.0–1.0 applied to open window to spread recovery load.
N4UGHTYLLM_GATE_CIRCUIT_BREAKER_JITTER_FACTOR=0.1

# ─── Port routing & Docker upstreams ─────────────────────
# Numeric token → forward to host.docker.internal:{port}/v1
# On bare metal set N4UGHTYLLM_GATE_ENABLE_LOCAL_PORT_ROUTING=true yourself
N4UGHTYLLM_GATE_ENABLE_LOCAL_PORT_ROUTING=false
# For bare metal use 127.0.0.1
N4UGHTYLLM_GATE_LOCAL_PORT_ROUTING_HOST=host.docker.internal
# Auto-register token → Docker service (overrides port routing). Format token:service[:port], comma-separated.
# Example: 8317:cli-proxy-api,8080:sub2api,3000:aiclient2api
# N4UGHTYLLM_GATE_DOCKER_UPSTREAMS=8317:cli-proxy-api,8080:sub2api,3000:aiclient2api

# ─── v2 proxy (generic HTTP/HTTPS forward) ───────────────
N4UGHTYLLM_GATE_ENABLE_V2_PROXY=true
N4UGHTYLLM_GATE_V2_ENABLE_REQUEST_REDACTION=true
N4UGHTYLLM_GATE_V2_ENABLE_RESPONSE_COMMAND_FILTER=true
# true: minimal false-positive mode (HTTP smuggling / splitting / framing only)
N4UGHTYLLM_GATE_V2_RESPONSE_FILTER_OBVIOUS_ONLY=true
# Empty = any target; production should list trusted hosts
N4UGHTYLLM_GATE_V2_TARGET_ALLOWLIST=
# Comma-separated; example.com / .example.com / *.example.com
N4UGHTYLLM_GATE_V2_RESPONSE_FILTER_BYPASS_HOSTS=
N4UGHTYLLM_GATE_V2_RESPONSE_FILTER_MAX_CHARS=200000
N4UGHTYLLM_GATE_V2_SSE_FILTER_PROBE_MAX_CHARS=4000
# Block v2 targets that resolve to private/internal IPs (SSRF)
N4UGHTYLLM_GATE_V2_BLOCK_INTERNAL_TARGETS=true

# ─── Semantic module (built-in TF-IDF, no GPU) ───────────
N4UGHTYLLM_GATE_ENABLE_SEMANTIC_MODULE=true
N4UGHTYLLM_GATE_SEMANTIC_SERVICE_URL=
N4UGHTYLLM_GATE_SEMANTIC_GRAY_LOW=0.25
N4UGHTYLLM_GATE_SEMANTIC_GRAY_HIGH=0.75
N4UGHTYLLM_GATE_SEMANTIC_TIMEOUT_MS=150
N4UGHTYLLM_GATE_SEMANTIC_CACHE_TTL_SECONDS=300
N4UGHTYLLM_GATE_SEMANTIC_CIRCUIT_FAILURE_THRESHOLD=3
N4UGHTYLLM_GATE_SEMANTIC_CIRCUIT_OPEN_SECONDS=30

# ─── Filter toggles (default on; uncomment to disable) ───
# N4UGHTYLLM_GATE_ENABLE_REDACTION=true
# N4UGHTYLLM_GATE_ENABLE_EXACT_VALUE_REDACTION=true
# N4UGHTYLLM_GATE_ENABLE_RESTORATION=true
# N4UGHTYLLM_GATE_ENABLE_INJECTION_DETECTOR=true
# N4UGHTYLLM_GATE_ENABLE_PRIVILEGE_GUARD=true
# N4UGHTYLLM_GATE_ENABLE_ANOMALY_DETECTOR=true
# N4UGHTYLLM_GATE_ENABLE_REQUEST_SANITIZER=true
# N4UGHTYLLM_GATE_ENABLE_OUTPUT_SANITIZER=true
# N4UGHTYLLM_GATE_ENABLE_POST_RESTORE_GUARD=true
# N4UGHTYLLM_GATE_ENABLE_SYSTEM_PROMPT_GUARD=false
# N4UGHTYLLM_GATE_ENABLE_UNTRUSTED_CONTENT_GUARD=true
# N4UGHTYLLM_GATE_ENABLE_TOOL_CALL_GUARD=true
# N4UGHTYLLM_GATE_ENABLE_RAG_POISON_GUARD=true

# ─── Storage ─────────────────────────────────────────────
N4UGHTYLLM_GATE_STORAGE_BACKEND=sqlite
N4UGHTYLLM_GATE_SQLITE_DB_PATH=logs/n4ughtyllm_gate.db
N4UGHTYLLM_GATE_AUDIT_LOG_PATH=logs/audit.jsonl
N4UGHTYLLM_GATE_ENABLE_DANGEROUS_RESPONSE_LOG=false
# Rotates to dangerous_response_samples-YYYY-MM-DD.jsonl; prunes files older than ~10 days
N4UGHTYLLM_GATE_DANGEROUS_RESPONSE_LOG_PATH=logs/dangerous_response_samples.jsonl
# N4UGHTYLLM_GATE_REDIS_URL=redis://127.0.0.1:6379/0
# N4UGHTYLLM_GATE_POSTGRES_DSN=postgresql://<user>:<password>@127.0.0.1:5432/n4ughtyllm_gate
