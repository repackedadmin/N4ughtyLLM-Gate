# Example: Caddy + N4ughtyLLM Gate on the public internet
#
# Flow: client → https://api.example.com/v1/__gw__/t/8317/... → Caddy → N4ughtyLLM Gate:18080 → localhost:8317
#
# Choose reverse_proxy upstream for your layout:
#   - Caddy and gateway on the same Compose network: n4ughtyllm_gate:18080
#   - Caddy on host, gateway in Docker: 127.0.0.1:18080 (published port)
#   - Both on host: 127.0.0.1:18080
#   - Caddy elsewhere: <gateway-host>:18080
#
# Notes:
#   - flush_interval -1: required for SSE (no buffering)
#   - response_header_timeout 660s: long inference
#   - /__gw__/* → 403: do not expose admin APIs publicly
#   - X-N4ughtyLLM-Gate-Proxy-Token: optional trust header between Caddy and the gateway
#   - Put upstream admin UIs on another hostname, not through the gateway
#   - Caddy does TLS + proxy only; routing stays inside the gateway
#
# Open 80/443; Caddy obtains certificates automatically.

# Optional static site (unrelated to the gateway; delete if unused)
# example.com, www.example.com {
#     header {
#         X-Content-Type-Options "nosniff"
#         X-Frame-Options "SAMEORIGIN"
#         Referrer-Policy "strict-origin-when-cross-origin"
#         Permissions-Policy "geolocation=(), microphone=(), camera=()"
#         -Server
#     }
#     header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
#     root * /srv/www
#     file_server
# }

# API: TLS termination then N4ughtyLLM Gate (see header for upstream host)
api.example.com {
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-XSS-Protection "1; mode=block"
        -Server
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    }
    # Block public access to gateway admin routes
    @gw_admin path /__gw__ /__gw__/*
    respond @gw_admin "forbidden" 403

    # Drop common scanner paths (less log noise)
    @scanner_probe {
        path /assets/* /static/* /js/* /css/* /images/* /img/* /fonts/*
        path /robots.txt /favicon.ico /sitemap.xml /.env /wp-login.php /wp-admin/*
        path /.git/* /.svn/* /.DS_Store /server-status /server-info
        path /phpmyadmin/* /pma/* /admin/* /administrator/* /cgi-bin/*
    }
    respond @scanner_probe 404

    # Only /v1/* and /v2/* to the gateway
    @not_api {
        not path /v1/* /v2/*
    }
    respond @not_api 404

    # On Docker host use 127.0.0.1:18080 (see top of file)
    reverse_proxy 127.0.0.1:18080 {
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Real-IP {remote_host}
        # Optional: set env N4UGHTYLLM_GATE_PROXY_TOKEN in Caddy, then uncomment:
        # header_up X-N4ughtyLLM-Gate-Proxy-Token {env.N4UGHTYLLM_GATE_PROXY_TOKEN}
        flush_interval -1
        transport http {
            response_header_timeout 660s
            read_timeout 660s
            write_timeout 660s
        }
    }
}

# Optional upstream admin UI (direct to upstream, not through the gateway).
# Replace host/port (CLIProxyAPI 8317, Sub2API 8080, AIClient-2-API 3000).
# Restrict by IP in production.
# panel.example.com {
#     @allowed remote_ip YOUR_ADMIN_IP/32
#     handle @allowed {
#         reverse_proxy localhost:8317 {
#             flush_interval -1
#             transport http {
#                 response_header_timeout 660s
#                 read_timeout 660s
#                 write_timeout 660s
#             }
#         }
#     }
#     respond "forbidden" 403
# }
